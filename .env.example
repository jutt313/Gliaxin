# ─────────────────────────────────────────────────────────────
# Gliaxin OSS — Environment Variables
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────

# ── App / Backend ────────────────────────────────────────────
# Your personal API key — set this to any secret string.
# All SDK hooks and API calls must send X-Api-Key: <this value>.
OSS_API_KEY=your-secret-api-key-here

# A fixed UUID for your personal project. Generate one with: python -c "import uuid; print(uuid.uuid4())"
OSS_PROJECT_ID=00000000-0000-0000-0000-000000000001

# Human-readable name for the project (optional)
OSS_PROJECT_NAME=Personal

# Port the API listens on (default: 9823)
PORT=9823

# CORS origins for local dev (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# ── Database ─────────────────────────────────────────────────
# Connection string for your Postgres (with pgvector) database.
# Using docker-compose: the API container uses the internal hostname "db".
# Running locally: use localhost.
DATABASE_URL=postgresql://gliaxin:gliaxin@localhost:5432/gliaxin

# ── LLM Provider ─────────────────────────────────────────────
# Choose your provider: gemini | openai | claude | kimi
ACTIVE_LLM_PROVIDER=gemini

# ── Gemini ───────────────────────────────────────────────────
# Required when ACTIVE_LLM_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_GEN_MODEL=gemini-2.5-flash
GEMINI_EMBED_MODEL=gemini-embedding-001

# ── OpenAI ───────────────────────────────────────────────────
# Required when ACTIVE_LLM_PROVIDER=openai
# Also required as the embedding provider when using claude or kimi.
OPENAI_API_KEY=
OPENAI_GEN_MODEL=gpt-4o-mini
OPENAI_EMBED_MODEL=text-embedding-3-small

# ── Anthropic Claude ─────────────────────────────────────────
# Required when ACTIVE_LLM_PROVIDER=claude
# NOTE: Claude has no embedding API. Set OPENAI_API_KEY above for embeddings.
ANTHROPIC_API_KEY=
CLAUDE_GEN_MODEL=claude-sonnet-4-6

# ── Kimi (Moonshot AI) ───────────────────────────────────────
# Required when ACTIVE_LLM_PROVIDER=kimi
# NOTE: Kimi has no embedding API. Set OPENAI_API_KEY above for embeddings.
KIMI_API_KEY=
KIMI_GEN_MODEL=moonshot-v1-8k
